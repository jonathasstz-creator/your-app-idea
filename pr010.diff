+    @staticmethod
+    def _build_steps_payload(notes: List[dict]) -> List[dict]:
+        """
+        Group notes by start_beat into proper 'steps' for polyphonic support (V2).
+        Each step: {
+          step_index: int,
+          start_beat: float,
+          midi: List[int],
+          duration_beats: float,
+          notes: List[dict]  # original V1 notes for debug/rendering
+        }
+        """
+        # 1. Group by start_beat (fuzzy match to avoid float precision issues)
+        groups = {}
+        for note in notes:
+            beat_key = int(round(note["start_beat"] * 1000))
+            if beat_key not in groups:
+                groups[beat_key] = []
+            groups[beat_key].append(note)
+
+        # 2. Sort by beat
+        sorted_keys = sorted(groups.keys())
+
+        # 3. Build steps
+        steps = []
+        for idx, key in enumerate(sorted_keys):
+            group_notes = groups[key]
+            # Deterministic sort within chord (midis ascending)
+            group_notes.sort(key=lambda x: x["midi"])
+            
+            first = group_notes[0]
+            steps.append({
+                "step_index": idx,
+                "start_beat": first["start_beat"],
+                "duration_beats": first["duration_beats"], # using first note's duration as step duration
+                "midi": [n["midi"] for n in group_notes],
+                "notes": group_notes
+            })
+        
+        return steps
