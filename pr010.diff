+
+export function buildV2StepToCursorMapping(osmd: any, steps: any[]): number[] {
+  if (!osmd || !steps.length) return [];
+
+  // Reuse existing logic to find linear positions etc
+  // But we need to map steps -> cursor index
+
+  const cursor = osmd.cursor;
+  const posBySignature = new Map<string, number>();
+  const linearPositions: number[] = [];
+
+  cursor.reset();
+  cursor.show?.();
+  let pIdx = 0;
+  while (!cursor.Iterator.EndReached && pIdx < 5000) {
+    linearPositions.push(pIdx);
+
+    const entries = cursor.Iterator.CurrentVoiceEntries || [];
+    entries.forEach((entry: any) => {
+      const staffEntry = entry.SourceStaffEntry || entry.sourceStaffEntry;
+      const staff = extractStaffFromEntry(staffEntry, cursor.Iterator);
+      const mIdx = extractMeasureIndex(staffEntry, cursor.Iterator);
+      const beat = extractBeatIndex(staffEntry);
+
+      (entry.Notes || entry.notes || []).forEach((note: any) => {
+        if (isRestNote(note)) return;
+        const midi = extractMidiFromOsmdNote(note);
+        if (isNumber(midi)) {
+          // For polyphony steps, we use the signature of *any* note in that step
+          // But since cursor is typically per-chord, signature like "treble|0|0" (geo) is best shared key
+
+          // Assinatura geográfica: Pentagrama | Compasso | Tempo
+          const geoSig = `${staff}|${mIdx}|${beat}`;
+          if (!posBySignature.has(geoSig)) posBySignature.set(geoSig, pIdx);
+
+          // Also specific note signature for fallback
+          const sig = `${staff}|${mIdx}|${beat}|${midi}`;
+          if (!posBySignature.has(sig)) posBySignature.set(sig, pIdx);
+        }
+      });
+    });
+    cursor.next();
+    pIdx++;
+  }
+  cursor.reset();
+
+  const mapping = steps.map((step, i) => {
+    // Use the first note of the step to find signature
+    // Ideally steps should track which staff they belong to, or we assume treble/merged
+    // If step has notes, take first
+    const firstNote = step.notes && step.notes.length > 0 ? step.notes[0] : null;
+    if (!firstNote) return linearPositions[Math.min(i, linearPositions.length - 1)] || 0;
+
+    const staff = normalizeStaffName(firstNote.staff);
+    const mIdx = toNum(firstNote.measure_index) || 0;
+    const beat = normalizeBeat(firstNote.beat ?? step.start_beat) || 0;
+
+    // Try matching the specific first note
+    const midi = firstNote.midi;
+    const sig = `${staff}|${mIdx}|${beat}|${midi}`;
+    const geoSig = `${staff}|${mIdx}|${beat}`;
+
+    let pos = posBySignature.get(sig) ?? posBySignature.get(geoSig);
+    if (!isNumber(pos)) {
+      pos = linearPositions[Math.min(i, linearPositions.length - 1)] || 0;
+    }
+    return pos;
+  });
+
+  console.log(`[Mapping V2] ${steps.length} steps mapped.`);
+  return mapping;
+}
