@@ -0,0 +1,113 @@
+"""
+PR1 Safety Net: V1 Schema Invariants for Chapters 1-22
+Validates that legacy lesson generation maintains strict constraints.
+"""
+import pytest
+from core.lessons.loader import get_chapter_by_id
+from core.config import AppConfig
+from core.practice_engine import PracticeEngine
+from app.services.lesson_snapshot import LessonSnapshotGenerator
+from app.models.catalog import Lesson
+# Assuming typical app setup, we might need a test client or direct generator usage.
+# Since we want to test the *generated* lesson structure (invariants), we can use PracticeEngine directly
+# or LessonSnapshotGenerator if that's what produces the final payload.
+# The user prompt used "LessonGenerator" but in this codebase it seems PracticeEngine + LessonSnapshotGenerator.
+
+# Explicitly exclude chapter 999 (polyphonic V2 test chapter)
+# Also note: Chapter 20 is skipped/missing in lessons.json
+V1_CHAPTERS = list(range(1, 20)) + [21, 22]
+
+@pytest.fixture
+def mock_lesson_generator():
+    return LessonSnapshotGenerator()
+
+@pytest.mark.parametrize("chapter_id", V1_CHAPTERS)
+def test_v1_total_steps_equals_notes_count(chapter_id):
+    """Invariant: total_steps must equal len(notes) for V1 schema."""
+    # We need to simulate generation
+    # Since we can't easily perform full DB setup here without conftest infrastructure availability check,
+    # allows try minimal setup if possible, or skip if environment not ready.
+    # Assuming standard pytest run in backend.
+    
+    # Using PracticeEngine directly to inspect logical lesson structure matching V1 expectations
+    cfg = AppConfig()
+    cfg.practice_mode = "wait"
+    engine = PracticeEngine(cfg)
+    try:
+        engine.start_lesson_by_chapter(chapter_id)
+    except Exception as e:
+         pytest.fail(f"Could not generate chapter {chapter_id}: {e}")
+
+    # Inspect the engine's lesson directly
+    # In V1, 1 step = 1 note.
+    # Engine lesson is List[LessonStep].
+    lesson_steps = engine.lesson
+    
+    # Check that each step corresponds to exactly one note visually (V1 style)
+    # The actual V1 *Schema* is produced by LessonSnapshotGenerator._build_notes_payload
+    # So we should check that output if possible.
+    
+    gen = LessonSnapshotGenerator()
+    notes_payload = gen._build_notes_payload(lesson_steps)
+    
+    # In V1, total_steps is len(notes)
+    assert len(lesson_steps) == len(notes_payload), \
+        f"Chapter {chapter_id}: steps={len(lesson_steps)} != notes={len(notes_payload)}"
+
+@pytest.mark.parametrize("chapter_id", V1_CHAPTERS)
+def test_v1_step_index_strictly_increasing(chapter_id):
+    """Invariant: step_index must be 0, 1, 2, ... N-1 (no gaps, no repeats)."""
+    cfg = AppConfig()
+    engine = PracticeEngine(cfg)
+    engine.start_lesson_by_chapter(chapter_id)
+    
+    gen = LessonSnapshotGenerator()
+    notes = gen._build_notes_payload(engine.lesson)
+    
+    for i, note in enumerate(notes):
+        assert note["step_index"] == i, (
+            f"Chapter {chapter_id} note {i}: expected step_index={i}, got {note['step_index']}"
+        )
+
+@pytest.mark.parametrize("chapter_id", V1_CHAPTERS)
+def test_v1_midi_is_integer(chapter_id):
+    """Invariant: midi must be int (not array, not float)."""
+    cfg = AppConfig()
+    engine = PracticeEngine(cfg)
+    engine.start_lesson_by_chapter(chapter_id)
+    
+    gen = LessonSnapshotGenerator()
+    notes = gen._build_notes_payload(engine.lesson)
+    
+    for i, note in enumerate(notes):
+        assert isinstance(note["midi"], int), (
+            f"Chapter {chapter_id} note {i}: midi is {type(note['midi'])}, expected int"
+        )
+        assert not isinstance(note["midi"], bool), "midi cannot be bool"
+
+@pytest.mark.parametrize("chapter_id", V1_CHAPTERS)
+def test_v1_start_beat_strictly_increasing(chapter_id):
+    """Invariant: start_beat must be strictly increasing (no simultaneous notes in V1)."""
+    cfg = AppConfig()
+    engine = PracticeEngine(cfg)
+    engine.start_lesson_by_chapter(chapter_id)
+    
+    gen = LessonSnapshotGenerator()
+    notes = gen._build_notes_payload(engine.lesson)
+    
+    for i in range(1, len(notes)):
+        prev_beat = notes[i - 1]["start_beat"]
+        curr_beat = notes[i]["start_beat"]
+        
+        # Note: In strict V1 (monophonic), start_beat usually increases.
+        # If there are chords, this invariant fails.
+        # Chapters 1-22 are *supposed* to be monophonic line? 
+        # If any chapter has chords, this test will correctly fail flagging it's not pure V1-compatible.
+        assert curr_beat > prev_beat, (
+            f"Chapter {chapter_id} notes {i-1}->{i}: "
+            f"start_beat not increasing ({prev_beat} -> {curr_beat})"
+        )
+
+def test_chapter_999_excluded_from_v1_tests():
+    """Meta-test: Verify chapter 999 is NOT in V1 test suite."""
+    assert 999 not in V1_CHAPTERS, "Chapter 999 should be excluded from V1 invariants"
